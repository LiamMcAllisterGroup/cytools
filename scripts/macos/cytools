#!/bin/bash
#
# CYTools launcher (macOS): starts JupyterLab in the CYTools conda environment.
# (Replaces the previous Docker-based launcher. Uses BSD getopts, not GNU getopt.)

set -euo pipefail

ENV_NAME="cytools"
NOTEBOOK_DIR="$HOME"
runbash=false
doupdate=false

showHelp() {
cat << EOF
CYTools: A software package for analyzing Calabi-Yau hypersurfaces in toric varieties.

Usage: cytools [OPTIONS]
Starts JupyterLab in the CYTools conda environment.

Options:
 -h, --help    Display help
 -d DIR        Directory to open JupyterLab in (default: \$HOME)
 -b, --bash    Start a shell in the CYTools environment instead of JupyterLab
     --update  Update CYTools (pip install -U cytools) in the environment

For more detailed instructions please visit https://cytools.liammcallistergroup.com
EOF
}

# parse args (BSD getopts + manual long options)
# ----------------------------------------------
while getopts "hbd:-:" OPT; do
  case "$OPT" in
    h) showHelp; exit 0 ;;
    b) runbash=true ;;
    d) NOTEBOOK_DIR="$OPTARG" ;;
    -) case "$OPTARG" in
         help)   showHelp; exit 0 ;;
         bash)   runbash=true ;;
         update) doupdate=true ;;
         *) echo "Unrecognized option --$OPTARG" >&2; exit 1 ;;
       esac ;;
    *) echo "Unrecognized option" >&2; exit 1 ;;
  esac
done

# locate conda (GUI apps don't inherit the shell PATH; include macOS/homebrew paths)
# ----------------------------------------------------------------------------------
CONDA=""
if [[ -n "${CONDA_EXE:-}" && -x "${CONDA_EXE}" ]]; then
  CONDA="$CONDA_EXE"
else
  for c in "$HOME/miniforge3" "$HOME/miniconda3" "$HOME/anaconda3" \
           "/opt/miniconda3" "/opt/anaconda3" "/opt/homebrew/Caskroom/miniforge/base"; do
    [[ -x "$c/bin/conda" ]] && { CONDA="$c/bin/conda"; break; }
  done
fi
if [[ -z "$CONDA" ]]; then
  echo "Error: could not find a conda installation." >&2
  echo "Install conda/miniforge and create the CYTools environment, or set CONDA_EXE." >&2
  exit 1
fi

# verify the environment exists
# -----------------------------
if ! "$CONDA" env list | awk '{print $1}' | grep -qx "$ENV_NAME"; then
  echo "Error: conda environment '$ENV_NAME' not found." >&2
  echo "Create it with: conda env create -f environment.yml" >&2
  exit 1
fi

# update path
# -----------
if $doupdate; then
  exec "$CONDA" run --no-capture-output -n "$ENV_NAME" pip install -U cytools
fi

# bash path
# ---------
if $runbash; then
  exec "$CONDA" run --no-capture-output -n "$ENV_NAME" bash
fi

