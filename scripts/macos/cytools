ver=$("$CONDA" run -n "$ENV_NAME" python -c "import importlib.metadata as m; print(m.version('cytools'))" 2>/dev/null || true)
if [[ -n "$ver" ]]; then echo "                     https://cy.tools | v$ver"; else echo "                       https://cy.tools"; fi
